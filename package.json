{
  "name": "@repull/mcp",
  "version": "0.2.1",
  "description": "Model Context Protocol (MCP) server for the Repull API — agent-friendly access to reservations, properties, listings, guests, and conversations across 50+ PMS platforms and the major OTAs (Airbnb, Booking.com, VRBO, Plumguide). Includes built-in discovery, docs, whoami, cursor pagination, idempotency keys, and full error envelopes (code/fix/docs_url) so AI agents can self-correct without escalating to a human.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "repull-mcp": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && chmod +x dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "start": "node dist/index.js",
    "dev": "tsc --watch -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@vitest/ui": "^4.1.5",
    "typescript": "^5.6.3",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "repull",
    "claude",
    "anthropic",
    "vacation-rental",
    "airbnb",
    "booking",
    "vrbo",
    "channel-manager",
    "pms",
    "hospitality"
  ],
  "homepage": "https://repull.dev",
  "bugs": {
    "url": "https://github.com/ivannikolovbg/repull-mcp/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ivannikolovbg/repull-mcp.git"
  },
  "author": "Divanova Inc. <hello@repull.dev>",
  "publishConfig": {
    "access": "public"
  },
  "mcpName": "io.github.ivannikolovbg/repull-mcp"
}
